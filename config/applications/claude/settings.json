{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Read(./secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "skipWebFetchPreflight": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "ENABLE_TOOL_SEARCH": true,
  "model": "sonnet[1m]"
}
